# VHS tape for the Prism README demo GIF.
# Render from the repo root:  vhs demo/demo.tape
Output demo/prism-demo.gif

Set Shell bash
Set FontSize 20
Set Width 1160
Set Height 780
Set Padding 28
Set TypingSpeed 45ms
Set Theme "Catppuccin Mocha"

Hide
Type 'export PS1="❯ "; source demo/prismrc.sh; clear'
Enter
Show
Sleep 800ms

Type "ask design a landing page for my product"
Sleep 500ms
Enter
Sleep 2500ms

Type "prism design a landing page for my product"
Sleep 500ms
Enter
Sleep 6s
